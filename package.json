{
  "name": "@blendsdk/tui-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for the @blendsdk/tui terminal UI SDK",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "check:deps": "turbo run check:deps",
    "verify": "turbo run typecheck build test",
    "gate": "node scripts/gate.mjs",
    "sync-versions": "node scripts/sync-versions.mjs",
    "bench": "yarn workspace @blendsdk/tui-core bench"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.10.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
